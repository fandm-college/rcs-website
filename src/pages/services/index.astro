---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { services } from '../../data/services.js';
---
<BaseLayout title="Services | Research Computing Services">
  <section class="page-hero"><div class="container"><h1>Services</h1><p>Explore the research computing services available to Franklin &amp; Marshall faculty, students, and collaborators.</p></div></section>
  <section class="section"><div class="container grid grid-3">{services.map((service) => <ServiceCard service={service} />)}</div></section>
</BaseLayout>
