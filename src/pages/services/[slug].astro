---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { services, getService } from '../../data/services.js';
import { siteInfo } from '../../data/site.js';
export function getStaticPaths() {
  return services.map((service) => ({ params: { slug: service.slug } }));
}
const service = getService(Astro.params.slug);
const isInternal = (href) => href && href.startsWith('/');
const base = import.meta.env.BASE_URL;
const linkHref = (href) => isInternal(href) ? `${base}${href.replace(/^\//, '')}` : href;
---
<BaseLayout title={`${service.title} | Research Computing Services`}>
  <section class="page-hero"><div class="container"><div class="eyebrow">Service</div><h1>{service.icon} {service.title}</h1><p>{service.summary}</p></div></section>
  <section class="section"><div class="container"><article class="content">
    <h2>Who this is for</h2><p>{service.audience}</p>
    <h2>Common tasks</h2><ul class="task-list">{service.tasks.map((task) => <li>{task}</li>)}</ul>
    <h2>Related links</h2><div class="link-list">{service.links.map((link) => <a class="link-pill" href={linkHref(link.href)}>{link.label}</a>)}</div>
    <h2>Need assistance?</h2><div class="contact-panel"><p>For help with {service.title}, email <a href={`mailto:${siteInfo.email}`}>{siteInfo.email}</a> or open a support ticket at <a href={siteInfo.requestPortal}>request.fandm.edu</a>.</p><p>When opening a ticket, include your username, course or project name, the service you are using, screenshots or error messages, and the steps you have already tried.</p></div>
  </article></div></section>
</BaseLayout>
