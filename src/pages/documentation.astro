---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const url = (path) => `${base}${path.replace(/^\//, '')}`;
---
<BaseLayout title="Documentation | Research Computing Services">
  <section class="page-hero"><div class="container"><h1>Documentation</h1><p>Guides and tutorials for using Research Computing Services.</p></div></section>
  <section class="section"><div class="container content">
    <h2>Faculty guides</h2>
    <div class="grid grid-3">
      <a class="card" href="https://fandm-college.github.io/globus/"><h3>Globus Faculty Guide</h3><p>Learn how to transfer and share research data with Globus.</p></a>
      <a class="card" href="https://fandm-college.github.io/jupyterhub-guide/"><h3>JupyterHub Faculty Guide</h3><p>Learn how to use JupyterHub for courses, notebooks, and teaching workflows.</p></a>
      <a class="card" href={url('/contact/')}><h3>Get Help</h3><p>Open a ticket or contact Research Computing Services.</p></a>
    </div>
  </div></section>
</BaseLayout>
