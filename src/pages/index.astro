---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import NewsCard from '../components/NewsCard.astro';
import { services } from '../data/services.js';
import { news } from '../data/news.js';
import { spotlight } from '../data/spotlight.js';

const base = import.meta.env.BASE_URL;
const url = (path) => `${base}${path.replace(/^\//, '')}`;
const spotlightImage = url(spotlight.image);

const heroSlides = [
  {
    eyebrow: '1 / 3',
    kicker: '',
    title: 'Accelerating<br />Research at F&amp;M',
    text: 'Research Computing Services provides the high performance computing, data, and expert support you need to advance discovery and scholarship.',
    image: url('/images/cluster-image.jpg'),
    imageAlt: 'Franklin & Marshall College campus at night',
    actions: [
      { label: 'Explore Services', href: url('/services/'), class: 'button button-primary' },
      { label: 'Request Support', href: 'https://request.fandm.edu/', class: 'button button-outline' },
    ],
  },
  {
    eyebrow: '2 / 3',
    kicker: '',
    title: 'Student Research Spotlight',
    text: 'Hackman Scholar, F&amp;M senior Zining Liu worked with F&amp;M Professor Brad McDanel and others on PipeSpec: Breaking Stage Dependencies in Hierarchical LLM Decoding. This work was presented at DAC&#39;25 and went on to be published in Association for Computational Linguistics.',
    image: url('/images/pipe-spec.png'),
    imageAlt: 'Placeholder image for student research spotlight',
    actions: [
      {
        label: 'Learn more...',
        href: 'https://drive.google.com/file/d/1PE88K8lA2vCn_DkVFSsBrwS7Oi1mz0mm/view',
        class: 'button button-primary',
      },
    ],
  },
  {
    eyebrow: '3 / 3',
    kicker: '',
    title: 'Faculty Research Spotlight',
    subtitle: spotlight.name,
    text: spotlight.summary,
    image: spotlightImage,
    imageAlt: 'Research image for faculty spotlight',
    actions: [
      { label: 'Learn more...', href: spotlight.href, class: 'button button-primary' },
    ],
  },
];
---

<BaseLayout title="Research Computing Services | Franklin & Marshall College">
  <section class="hero hero-split-carousel">
    <div
      class="hero-carousel"
      aria-label="Featured Research Computing content"
      data-hero-carousel
    >
      <button class="hero-carousel-arrow hero-carousel-prev" type="button" aria-label="Previous slide" data-carousel-prev>
        ‹
      </button>

      <div class="hero-carousel-slides">
        {heroSlides.map((slide, index) => (
          <article class={`hero-carousel-slide ${index === 0 ? 'is-active' : ''}`} data-carousel-slide>
            <div class="hero-carousel-copy">
              <div class="hero-slide-count">{slide.eyebrow}</div>
              {slide.kicker && <div class="kicker">{slide.kicker}</div>}

              <h1 set:html={slide.title} />
              {slide.subtitle && <h3>{slide.subtitle}</h3>}
              <p set:html={slide.text} />

              <div class="hero-actions">
                {slide.actions.map((action) => (
                  <a class={action.class} href={action.href}>{action.label}</a>
                ))}
              </div>
            </div>

            <div class="hero-carousel-image">
              <img src={slide.image} alt={slide.imageAlt} />
            </div>
          </article>
        ))}
      </div>

      <button class="hero-carousel-arrow hero-carousel-next" type="button" aria-label="Next slide" data-carousel-next>
        ›
      </button>

      <div class="hero-carousel-dots" aria-label="Carousel slide selection">
        {heroSlides.map((_, index) => (
          <button
            type="button"
            class={`hero-carousel-dot ${index === 0 ? 'is-active' : ''}`}
            aria-label={`Show slide ${index + 1}`}
            data-carousel-dot={index}
          />
        ))}
      </div>
    </div>

    <aside class="hero-status-column">
      <div class="maintenance-card">
        <div class="maintenance-icon">⚠️</div>
        <div>
          <h2>Scheduled Maintenance</h2>
          <p>
            Cluster will be down for maintenance from July 20 through July 27.
          </p>
        </div>
      </div>

      <div class="hero-panel">
        <h2>System Status</h2>
        <div class="status-list">
          <div class="status-item"><span>HPC Cluster</span><span class="status-ok">Operational</span></div>
          <div class="status-item"><span>JupyterHub</span><span class="status-ok">Operational</span></div>
          <div class="status-item"><span>Globus</span><span class="status-ok">Operational</span></div>
          <div class="status-item"><span>Storage</span><span class="status-ok">Operational</span></div>
          <div class="status-item"><span>RStudio</span><span class="status-ok">Operational</span></div>
          <div class="status-item"><span>WebWork</span><span class="status-ok">Operational</span></div>
        </div>
        <a class="status-link" href={url('/status/')}>View full status page →</a>
      </div>
    </aside>
  </section>

  <section class="section band">
    <div class="container">
      <div class="section-heading">
        <div>
          <h2>I want to...</h2>
          <p>Start with the task you need to complete. We will guide you to the right service or support path.</p>
        </div>
      </div>

      <div class="grid grid-4">
        <a class="card quick-card" href={url('/services/hpc/')}>
          <h3>Run a computation</h3>
          <p>Use campus computing resources for research jobs.</p>
        </a>

        <a class="card quick-card" href={url('/services/jupyterhub/')}>
          <h3>Use JupyterHub</h3>
          <p>Teach or learn with browser-based notebooks.</p>
        </a>

        <a class="card quick-card" href={url('/services/globus/')}>
          <h3>Transfer data</h3>
          <p>Move and share research data reliably.</p>
        </a>

        <a class="card quick-card" href={url('/services/national-resources/')}>
          <h3>Use national resources</h3>
          <p>Explore ACCESS, Jetstream2, and OSG.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div>
          <h2>Services</h2>
          <p>Local and external resources for computational research, teaching, and data-intensive work.</p>
        </div>
        <a href={url('/services/')}>All services →</a>
      </div>

      <div class="grid grid-4">
        {services.slice(0, 8).map((service) => <ServiceCard service={service} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div>
          <h2>Latest News</h2>
          <p>Updates from Research Computing Services and the F&amp;M research community.</p>
        </div>
        <a href={url('/news/')}>All news →</a>
      </div>

      <div class="grid grid-3">
        {news.map((item) => <NewsCard item={item} />)}
      </div>
    </div>
  </section>

  <script>
    const carousel = document.querySelector('[data-hero-carousel]');
    const slides = Array.from(document.querySelectorAll('[data-carousel-slide]'));
    const dots = Array.from(document.querySelectorAll('[data-carousel-dot]'));
    const prevButton = document.querySelector('[data-carousel-prev]');
    const nextButton = document.querySelector('[data-carousel-next]');

    let currentSlide = 0;
    let timer;
    const delay = 5000;

    function showSlide(index) {
      currentSlide = (index + slides.length) % slides.length;

      slides.forEach((slide, slideIndex) => {
        slide.classList.toggle('is-active', slideIndex === currentSlide);
      });

      dots.forEach((dot, dotIndex) => {
        dot.classList.toggle('is-active', dotIndex === currentSlide);
      });
    }

    function startTimer() {
      stopTimer();
      timer = window.setInterval(() => {
        showSlide(currentSlide + 1);
      }, delay);
    }

    function stopTimer() {
      if (timer) {
        window.clearInterval(timer);
      }
    }

    function manuallyShowSlide(index) {
      showSlide(index);
      startTimer();
    }

    prevButton?.addEventListener('click', () => manuallyShowSlide(currentSlide - 1));
    nextButton?.addEventListener('click', () => manuallyShowSlide(currentSlide + 1));

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => manuallyShowSlide(index));
    });

    carousel?.addEventListener('mouseenter', stopTimer);
    carousel?.addEventListener('mouseleave', startTimer);
    carousel?.addEventListener('focusin', stopTimer);
    carousel?.addEventListener('focusout', startTimer);

    startTimer();
  </script>
</BaseLayout>