---
const base = import.meta.env.BASE_URL;
const url = (path) => `${base}${path.replace(/^\//, '')}`;

const navItems = [
  { label: "Home", href: "/" },
  { label: "Services", href: "/services/" },
  { label: "Documentation", href: "/documentation/" },
  { label: "Training", href: "/training/" },
  { label: "Research", href: "/research/" },
  { label: "News", href: "/news/" },
  { label: "Contact", href: "/contact/" },
];
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href={url('/')} aria-label="Franklin & Marshall College home">
      <img src={url('/images/fm-logo.png')} alt="Franklin & Marshall College" />
    </a>

    <span class="brand-divider" aria-hidden="true"></span>

    <span class="brand-title">Research Computing Services</span>

    <nav class="nav" aria-label="Primary navigation">
      {navItems.map((item) => (
        <a href={url(item.href)}>{item.label}</a>
      ))}
    </nav>

    <button class="search-button" aria-label="Search">⌕</button>
  </div>
</header>