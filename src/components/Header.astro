---
const base = import.meta.env.BASE_URL;
const url = (path) => `${base}${path.replace(/^\//, '')}`;
const nav = [
  ['/', 'Home'],
  ['/services/', 'Services'],
  ['/documentation/', 'Documentation'],
  ['/training/', 'Training'],
  ['/research/', 'Research'],
  ['/news/', 'News'],
  ['/contact/', 'Contact']
];
---
<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={url('/')} aria-label="Research Computing Services home">
      <img src={url('/logos/fm-logo.png')} alt="Franklin & Marshall College" />
      <span>
        <span class="brand-title">Research Computing Services</span><br />
        <span class="brand-subtitle">Franklin &amp; Marshall College</span>
      </span>
    </a>
    <nav class="nav" aria-label="Primary navigation">
      {nav.map(([href, label]) => <a href={url(href)}>{label}</a>)}
    </nav>
  </div>
</header>
