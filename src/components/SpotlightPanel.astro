---
import { spotlight } from '../content/research';
---
<section class="panel spotlight-panel">
  <h2>Research Spotlight</h2>
  <img src={spotlight.image} alt="Abstract research visualization" />
  <h3>{spotlight.title}</h3>
  <p>{spotlight.excerpt}</p>
  <a class="text-link" href={spotlight.href}>See more research →</a>
</section>
