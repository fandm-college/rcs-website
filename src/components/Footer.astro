---
import { siteInfo } from '../data/site.js';
const base = import.meta.env.BASE_URL;
const url = (path) => `${base}${path.replace(/^\//, '')}`;
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h2>{siteInfo.name}</h2>
      <p>{siteInfo.college}</p>
      <p>{siteInfo.location}</p>
      <p><a href={`mailto:${siteInfo.email}`}>{siteInfo.email}</a></p>
    </div>
    <div>
      <h3>Guides</h3>
      <p><a href="https://fandm-college.github.io/globus/">Globus Faculty Guide</a></p>
      <p><a href="https://fandm-college.github.io/jupyterhub-guide/">JupyterHub Faculty Guide</a></p>
    </div>
    <div>
      <h3>Support</h3>
      <p><a href="https://request.fandm.edu">Open a support ticket</a></p>
      <p><a href={url('/contact/')}>Contact Research Computing</a></p>
    </div>
  </div>
</footer>
