---
import { news } from '../content/news';
const { limit = 4, featured = false } = Astro.props;
const items = news.slice(0, limit);
---
<section class={featured ? 'news-list featured-news' : 'panel'}>
  {!featured && <h2>Latest News</h2>}
  {items.map((item) => (
    <article class="news-item">
      {featured && <img src={item.image} alt="" />}
      <div>
        <small>{item.date}</small>
        <h3><a href={item.href}>{item.title}</a></h3>
        {featured && <p>{item.excerpt}</p>}
        <a class="text-link" href={item.href}>Read more →</a>
      </div>
    </article>
  ))}
  {!featured && <a class="text-link" href="/news/">View all news →</a>}
</section>
