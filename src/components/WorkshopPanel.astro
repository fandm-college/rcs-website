---
import { workshops } from '../content/workshops';
---
<section class="panel">
  <h2>Upcoming Workshops</h2>
  <ul class="workshop-list">
    {workshops.map((item) => <li><a href={item.href}><strong>{item.title}</strong><small>{item.date} · {item.time}</small></a></li>)}
  </ul>
  <a class="text-link" href="/training/">View all workshops →</a>
</section>
