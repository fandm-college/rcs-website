---
import { systemStatus } from '../content/status';
---
<section class="panel">
  <h2>System Status</h2>
  <ul class="status-list">
    {systemStatus.map((item) => <li><span class="status-dot"></span><div><strong>{item.name}</strong><small>{item.status}</small></div></li>)}
  </ul>
  <a class="text-link" href="/services/">View full status page →</a>
</section>
