---
const { item } = Astro.props;
const base = import.meta.env.BASE_URL;
const isExternal = item.href?.startsWith('http') || item.href?.startsWith('mailto:') || item.href === '#';
const href = isExternal ? item.href : `${base}${item.href.replace(/^\//, '')}`;
const image = item.image ? `${base}${item.image.replace(/^\//, '')}` : undefined;
---
<article class="card news-card">
  {image && <img src={image} alt="" />}
  <div class="news-card-body">
    <div class="kicker">{item.date}</div>
    <h3><a href={href}>{item.title}</a></h3>
    <p>{item.summary}</p>
  </div>
</article>
